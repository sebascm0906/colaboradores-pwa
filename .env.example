# ══════════════════════════════════════════════════════════════════
#  GF PWA Colaboradores — Variables de Entorno
#  Copiar como .env.local para desarrollo local
#  En Vercel: configurar en Project Settings > Environment Variables
# ══════════════════════════════════════════════════════════════════

# ── n8n (PRODUCCIÓN) ──────────────────────────────────────────────
# Instancia self-hosted: n8n.grupofrio.mx
# NO usar car12los023.app.n8n.cloud (deprecado)
VITE_N8N_WEBHOOK_URL=https://n8n.grupofrio.mx/webhook

# ── Voice-to-Form PoC (Fase 0 — ScreenMerma) ──────────────────────
# W120 OPS_W120_voice_intake_v2   (push-to-talk -> Deepgram -> OpenAI -> envelope)
# W122 OPS_W122_voice_feedback_v1 (AI vs humano diff para entrenar calidad)
# VITE_N8N_VOICE_TOKEN: bearer compartido con la var N8N_VOICE_TOKEN del .env
# del server /opt/kold-n8n/.env. Rotable con scripts/voice/init_token.mjs.
# NUNCA commitear el valor real (va solo en .env.local).
VITE_N8N_VOICE_WEBHOOK_URL=https://n8n.grupofrio.mx/webhook/voice-intake
VITE_N8N_VOICE_FEEDBACK_URL=https://n8n.grupofrio.mx/webhook/voice-feedback
VITE_N8N_VOICE_TOKEN=REEMPLAZAR_CON_TOKEN_GENERADO_POR_init_token_mjs

# ── Odoo (PRODUCCIÓN) ────────────────────────────────────────────
VITE_ODOO_URL=https://grupofrio.odoo.com

# ── PWA Identity ──────────────────────────────────────────────────
VITE_APP_NAME=GF Colaboradores
VITE_APP_URL=https://colaboradores.grupofrio.mx
VITE_APP_ID=pwa_colaboradores

# ── Metabase ──────────────────────────────────────────────────────
VITE_METABASE_URL=https://bi.grupofrio.mx

# ── WhatsApp — Canal Operaciones (EXCLUSIVO TROPA INTERNA) ────────
# Línea dedicada para OTP, notificaciones y alertas de colaboradores
# NO confundir con WA_PHONE_ID_KOLDHOME (B2C) ni el número principal B2B
#
# VITE_WA_PHONE_ID_OPERACIONES: expuesto al cliente solo para referencia de UI.
# WA_ACCESS_TOKEN_OPERACIONES: SERVER-SIDE ONLY — configurar en n8n (car12los023)
#   como variable de entorno. NUNCA con prefijo VITE_.
VITE_WA_PHONE_ID_OPERACIONES=REEMPLAZAR_CON_ID_DEL_NUMERO_WA_OPERACIONES
WA_ACCESS_TOKEN_OPERACIONES=REEMPLAZAR_CON_TOKEN_WA_OPERACIONES

# ══════════════════════════════════════════════════════════════════
#  REGLA DE ORO:
#  Variables con VITE_ → visibles en el bundle del cliente (solo IDs, URLs).
#  Variables sin VITE_ → server-side únicamente (tokens, secrets, API keys).
#  WA_ACCESS_TOKEN_OPERACIONES vive en n8n, está aquí solo como referencia
#  de lo que Carlos debe configurar en la instancia car12los023.
# ══════════════════════════════════════════════════════════════════
